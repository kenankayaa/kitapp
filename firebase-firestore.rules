rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        'kenank4ya@gmail.com'
      ];
    }

    match /cmsSite/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cmsPages/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cmsBooks/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cmsPosts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1500
        && request.resource.data.key is string
        && request.resource.data.bookSlug is string;

      // Okur sadece kendi yorum metnini düzenleyebilir. Admin yorum metnini değiştiremez, yalnızca silebilir.
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.key == resource.data.key
        && request.resource.data.bookSlug == resource.data.bookSlug
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['text', 'updatedAt', 'editCount', 'editedByName'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1500;

      // Sadece site sahibi/admin silebilir.
      allow delete: if isAdmin();
    }


    // Eski sürümlerin oluşturduğu kayıtları okuyabilmek için tutuldu.
    match /readingProgress/{progressId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;

      // v10: Her okurun kaldığı yer artık kendi kullanıcı kaydının altında tutulur.
      // Böylece Firestore sorgu/izin hataları azalır.
      match /readingProgress/{progressId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update: if signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.bookSlug is string
          && request.resource.data.bookSlug.size() > 0
          && request.resource.data.chapterIndex >= 0;
        allow delete: if signedIn() && request.auth.uid == uid;
      }
    }
  }
}
